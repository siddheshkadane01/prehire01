# Dependencies
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
package-lock.json
yarn.lock

# Environment Variables - CRITICAL: Never commit these!
.env
.env.*
*.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Explicit paths to ensure env files are never tracked
frontend/.env
frontend/.env.*
frontend/*.env
backend/.env
backend/.env.*
backend/*.env
ai-service/.env
ai-service/.env.*
ai-service/*.env

# Keep .env.example files (templates without credentials)
!.env.example
!**/.env.example

# Build outputs
build/
dist/
out/
.next/
frontend/build/
backend/dist/

